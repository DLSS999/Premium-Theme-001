{%- liquid
  assign inventory_max = block_settings.inventory_max
  assign low_inventory_threshold = block_settings.low_inventory_threshold
  assign label = block_settings.label
  assign label_classes = 'fs-body-100'

  unless show_label
    assign label_classes = label_classes | append: ' visually-hidden'
  endunless

  assign low_inventory_threshold_to_num = low_inventory_threshold | plus: 0
-%}

<div
  class="inventory-counter product__block product__block--medium"
  data-inventory-counter
  data-low-inventory-threshold="{{ low_inventory_threshold }}"
  data-stock-countdown-max="{{ inventory_max }}"
  data-show-status-bar="{{ block_settings.show_status_bar }}"
  data-show-untracked-quantity="{{ block_settings.show_untracked_quantity }}"
  data-unavailable-text="{{ 'products.inventory.unavailable' | t }}"
  {{ block.shopify_attributes }}
>
  <div class="product__label-wrapper">
    <span class="product__label inventory-counter__label fs-body-100">{{ label }}</span>
  </div>
  <span class="inventory-counter__message fs-body-75">&nbsp;</span>

  <span class="inventory-counter__bar">
    <span class="inventory-counter__bar-progress" style="width: 100%;"></span>
  </span>

  <script type="application/json" data-product-inventory-json>
    {
      "inventory": {
        {%- for variant in product.variants -%}
          {%- liquid
            assign cinq_stock_status = variant.metafields.custom.stock_status.value | default: variant.metafields.custom.stock_status | strip
            assign inventory_management_for_json = variant.inventory_management
            assign inventory_policy_for_json = variant.inventory_policy
            assign inventory_quantity_for_json = variant.inventory_quantity

            if cinq_stock_status == 'in_stock'
              capture inventory_message
                echo 'В наявності'
              endcapture

              if inventory_management_for_json == blank
                assign inventory_management_for_json = 'shopify'
              endif

              if inventory_quantity_for_json <= 0
                assign inventory_quantity_for_json = 1
              endif
            elsif cinq_stock_status == 'preorder'
              capture inventory_message
                echo 'Під замовлення'
              endcapture

              assign inventory_policy_for_json = 'continue'

              if inventory_management_for_json == blank
                assign inventory_management_for_json = 'shopify'
              endif

              if inventory_quantity_for_json <= 0
                assign inventory_quantity_for_json = 1
              endif
            elsif cinq_stock_status == 'out_of_stock'
              capture inventory_message
                echo 'Немає в наявності'
              endcapture

              assign inventory_policy_for_json = 'deny'
              assign inventory_quantity_for_json = 0

              if inventory_management_for_json == blank
                assign inventory_management_for_json = 'shopify'
              endif
            elsif variant.available
              if variant.inventory_management == nil and block_settings.show_untracked_quantity
                capture inventory_message
                  echo 'products.inventory.in_stock' | t
                endcapture
              else
                if variant.inventory_management and variant.inventory_quantity > 0 and low_inventory_threshold_to_num > 0
                  if variant.inventory_quantity <= low_inventory_threshold_to_num
                    capture inventory_message
                      echo 'products.inventory.low_stock' | t: count: variant.inventory_quantity
                    endcapture
                  else
                    capture inventory_message
                      echo 'products.inventory.in_stock' | t
                    endcapture
                  endif
                else
                  if variant.inventory_policy == 'deny' and variant.inventory_quantity <= 0 and variant.requires_shipping
                    capture inventory_message
                      echo 'products.inventory.sold_out' | t
                    endcapture
                  elsif variant.inventory_policy == 'continue' and variant.inventory_quantity <= 0 and variant.requires_shipping
                    capture inventory_message
                      echo 'products.inventory.backordered' | t
                    endcapture
                  else
                    capture inventory_message
                    endcapture
                  endif
                endif
              endif
            else
              capture inventory_message
                echo 'products.inventory.sold_out' | t
              endcapture
            endif
          -%}
          "{{ variant.id }}": {
            "inventory_management": {{ inventory_management_for_json | json }},
            "inventory_policy": {{ inventory_policy_for_json | json }},
            "inventory_quantity": {{ inventory_quantity_for_json | json }},
            "inventory_message": {{ inventory_message | strip | json }},
            "stock_status": {{ cinq_stock_status | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      }
    }
  </script>
</div>
